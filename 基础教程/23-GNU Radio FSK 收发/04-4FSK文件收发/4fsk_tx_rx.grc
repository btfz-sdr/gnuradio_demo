      \u8BE5\u662F\uFF1A\noutput = gain * (2 * pi * \u0394f / samp_rate)\n\n# \u7B26\
      \u53F70 (-1)   --- 00\n# \u7B26\u53F71 (-0.333)   --- 01\n# \u7B26\u53F72 (+0.333)\
      \ --- 10\n# \u7B26\u53F73 (+1) --- 11"
