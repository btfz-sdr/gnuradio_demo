- name: epy_block_3
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass dual_stream_tag_relocator(gr.basic_block):\n\
      \    def __init__(self, vlen=64, target_tag=\"ofdm_sync_carr_offset\"):\n  \
      \      gr.basic_block.__init__(self,\n            name=\"Dual Stream Tag Relocator\"\
      ,\n            in_sig=[(np.complex64, vlen), (np.complex64, vlen)], # in0: \u539F\
      \u59CB(\u5E26Tag), in1: \u5EF6\u8FDF(\u76EE\u6807\u6570\u636E)\n           \
      \ out_sig=[(np.complex64, vlen)])\n        self.vlen = vlen\n        self.target_tag\
      \ = target_tag\n        \n        # \u5FC5\u987B\u7981\u7528\u81EA\u52A8\u4F20\
      \u64AD\uFF0C\u7531\u6211\u4EEC\u624B\u52A8\u5C06 in0 \u7684\u6807\u7B7E\u632A\
      \u7ED9 out\n        self.set_tag_propagation_policy(gr.TPP_DONT)\n\n    def\
      \ general_work(self, input_items, output_items):\n        in0 = input_items[0]\
      \ # \u539F\u59CB\u6D41\uFF1A\u7528\u6765\u53D6\u6807\u7B7E\n        in1 = input_items[1]\
      \ # \u5EF6\u8FDF\u6D41\uFF1A\u7528\u6765\u53D6\u6570\u636E\n        out = output_items[0]\n\
      \        \n        # \u53D6\u4E24\u4E2A\u8F93\u5165 Buffer \u7684\u4EA4\u96C6\
      \u957F\u5EA6\uFF0C\u786E\u4FDD\u540C\u6B65\u5904\u7406\n        n_input = min(len(in0),\
      \ len(in1))\n        n_output = len(out)\n        n_process = min(n_input, n_output)\n\
      \n        if n_process == 0:\n            return 0\n\n        for i in range(n_process):\n\
      \            # 1. \u4ECE in0 (\u539F\u59CB\u6D41) \u83B7\u53D6\u6240\u6709\u6807\
      \u7B7E\n            curr_tags = self.get_tags_in_window(0, i, i + 1)\n     \
      \       \n            # 2. \u8BA1\u7B97\u5F53\u524D\u8F93\u51FA\u7684\u7EDD\u5BF9\
      \u504F\u79FB\u91CF\n            abs_offset = self.nitems_written(0) + i\n  \
      \          \n            # 3. \u5C06 in0 \u7684\u6240\u6709\u6807\u7B7E\u91CD\
      \u65B0\u6253\u5728\u8F93\u51FA\u6D41\u5BF9\u5E94\u7684\u4F4D\u7F6E\u4E0A\n \
      \           # \u6B64\u65F6\u8F93\u51FA\u6D41\u7684\u6570\u636E\u5176\u5B9E\u6765\
      \u81EA\u4E8E in1\n            for t in curr_tags:\n                # \u5982\u679C\
      \u4F60\u60F3\u8FC7\u6EE4\u7279\u5B9A\u6807\u7B7E\uFF0C\u53EF\u4EE5\u5728\u8FD9\
      \u91CC\u52A0 if str(t.key) == self.target_tag\n                self.add_item_tag(0,\
      \ abs_offset, t.key, t.value, t.srcid)\n            \n            # 4. \u6838\
      \u5FC3\uFF1A\u8F93\u51FA\u6570\u636E\u4F7F\u7528 in1 (\u5EF6\u8FDF\u540E\u7684\
      \u6D41)\n            out[i] = in1[i]\n\n        # \u6D88\u8017\u4E24\u4E2A\u8F93\
      \u5165\u7684\u76F8\u540C\u957F\u5EA6\n        self.consume(0, n_process)\n \
      \       self.consume(1, n_process)\n        \n        return n_process\n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    target_tag: '"ofdm_sync_carr_offset" '
    vlen: fft_len
