      \            # \u6700\u540E\u4E00\u5E27\u9700\u8981\u7684\u7ED3\u675F\u4F4D\u7F6E\
      \u7D22\u5F15\u662F start_idx + frame_size\n            if len(self.buf0) < (start_idx\
      \ + self.frame_size):\n                # \u6570\u636E\u4E0D\u591F\uFF0C\u628A\
      \u89E6\u53D1\u70B9\u4E4B\u524D\u7684\u4E1C\u897F\u6254\u4E86\uFF0C\u4FDD\u7559\
      \u89E6\u53D1\u70B9\u5F00\u59CB\u7684\u90E8\u5206\uFF0C\u8DF3\u51FA\u7B49\u4E0B\
      \u6B21\n                self.buf0 = self.buf0[start_idx:]\n                self.buf1\
      \ = self.buf1[start_idx:]\n                self.bufT = self.bufT[start_idx:]\n\
      \                break\n            \n            # 3. \u68C0\u67E5\u8F93\u51FA\
      \u7A7A\u95F4\n            if (len(output_items[self.OUT_HDR0]) < output_count_hdr\
      \ + self.header_len or \n                len(output_items[self.OUT_PLD0]) <\
      \ output_count_pld + self.payload_len):\n                # \u8F93\u51FA\u7A7A\
      \u95F4\u4E0D\u8DB3\uFF0C\u4FDD\u7559\u5F53\u524D\u89E6\u53D1\u70B9\u4F4D\u7F6E\
      \uFF0C\u8DF3\u51FA\u5FAA\u73AF\n                self.buf0 = self.buf0[start_idx:]\n\
      \                self.buf1 = self.buf1[start_idx:]\n                self.bufT\
      \ = self.bufT[start_idx:]\n                break\n\n            # 4. \u63D0\u53D6\
      \ Header (\u786E\u4FDD s:e \u7EDD\u5BF9\u5408\u6CD5)\n            try:\n   \
      \             for i in range(self.header_len):\n                    s = start_idx\
      \ + i * self.sym_size + self.gi\n                    e = s + self.ips\n    \
      \                output_items[self.OUT_HDR0][output_count_hdr + i] = self.buf0[s:e]\n\
      \                    output_items[self.OUT_HDR1][output_count_hdr + i] = self.buf1[s:e]\n\
