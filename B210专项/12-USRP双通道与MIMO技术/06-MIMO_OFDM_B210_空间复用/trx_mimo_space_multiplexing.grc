- name: epy_block_7_0
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\nimport\
      \ threading\nfrom collections import deque\n\nclass mimo_precision_decoder(gr.sync_block):\n\
      \    def __init__(self, fft_len=64, items_per_frame=10, path_id=1, max_cache=2000,\
      \ delay_syms=500, alpha=0.01):\n        gr.sync_block.__init__(\n          \
      \  self,\n            name=f\"mimo_precision_decoder_rx{path_id}\",\n      \
      \      in_sig=[(np.complex64, fft_len)],\n            out_sig=[(np.complex64,\
      \ fft_len)]\n        )\n        self.fft_len = fft_len\n        self.path_id\
      \ = path_id\n        self.items_per_frame = items_per_frame\n        self.max_cache\
      \ = max_cache\n        self.alpha = alpha \n        \n        # 1. \u5185\u90E8\
      \u5EF6\u8FDF\u7EBF (FIFO) - \u5B58\u50A8\u672C\u5730\u63A5\u6536\u5230\u7684\
      \u6570\u636E\u4EE5\u7B49\u5F85\u8FDC\u7A0B\u6570\u636E\u5BF9\u9F50\n       \
      \ self.delay_syms = delay_syms\n        self.local_fifo = deque([(\"None\",\
      \ np.zeros(fft_len, dtype=np.complex64)) for _ in range(delay_syms)])\n\n  \
      \      # 2. \u6D88\u606F\u7AEF\u53E3\n        self.message_port_register_in(pmt.intern(\"\
      y_in\"))\n        self.message_port_register_out(pmt.intern(\"y_out\"))\n  \
      \      self.message_port_register_in(pmt.intern(\"h_local_in\"))\n        self.message_port_register_in(pmt.intern(\"\
      h_remote_in\"))\n\n        self.set_msg_handler(pmt.intern(\"y_in\"), self.handle_y_msg)\n\
      \        self.set_msg_handler(pmt.intern(\"h_local_in\"), self.handle_h_local_msg)\n\
      \        self.set_msg_handler(pmt.intern(\"h_remote_in\"), self.handle_h_remote_msg)\n\
      \n        # 3. \u7F13\u5B58\u4E0E\u5E73\u6ED1\u77E9\u9635\n        self.remote_y_buffer\
      \ = {}\n        self.buffer_lock = threading.Lock()\n        \n        # \u521D\
      \u59CB\u5316 H \u77E9\u9635\u5206\u91CF (\u9ED8\u8BA4\u521D\u59CB\u5316\u4E3A\
      \u5355\u4F4D\u9635)\n        self.h11 = np.ones(fft_len, dtype=np.complex64)\n\
      \        self.h12 = np.zeros(fft_len, dtype=np.complex64)\n        self.h21\
      \ = np.zeros(fft_len, dtype=np.complex64)\n        self.h22 = np.ones(fft_len,\
      \ dtype=np.complex64)\n\n        self.active_base_ts = \"None\"\n\n    def handle_y_msg(self,\
      \ msg):\n        if pmt.is_pair(msg):\n            ts_str = str(pmt.to_python(pmt.car(msg)))\n\
      \            data = pmt.to_python(pmt.cdr(msg))\n            with self.buffer_lock:\n\
      \                self.remote_y_buffer[ts_str] = np.array(data, dtype=np.complex64)\n\
      \                if len(self.remote_y_buffer) > self.max_cache:\n          \
      \          self.remote_y_buffer.pop(next(iter(self.remote_y_buffer)))\n\n  \
      \  def _update_h_smooth(self, h_a_new, h_b_new, is_local):\n        a = self.alpha\n\
      \        with self.buffer_lock:\n            # \u8FD9\u91CC\u7684\u903B\u8F91\
      \u5FC5\u987B\u4E25\u683C\u5BF9\u5E94 C++ \u7AEF\u53D1\u9001 h_a/h_b \u7684\u7269\
      \u7406\u542B\u4E49\n            if self.path_id == 1:\n                if is_local:\
      \ \n                    self.h11 = (1-a)*self.h11 + a*h_a_new\n            \
      \        self.h12 = (1-a)*self.h12 + a*h_b_new\n                else:      \
      \ \n                    self.h21 = (1-a)*self.h21 + a*h_a_new\n            \
      \        self.h22 = (1-a)*self.h22 + a*h_b_new\n            else:\n        \
      \        if is_local: \n                    self.h21 = (1-a)*self.h21 + a*h_a_new\n\
      \                    self.h22 = (1-a)*self.h22 + a*h_b_new\n               \
      \ else:       \n                    self.h11 = (1-a)*self.h11 + a*h_a_new\n\
      \                    self.h12 = (1-a)*self.h12 + a*h_b_new\n\n    def handle_h_local_msg(self,\
      \ msg):\n        try:\n            d = pmt.to_python(pmt.cdr(msg))\n       \
      \     self._update_h_smooth(np.array(d['h_a']), np.array(d['h_b']), True)\n\
      \        except: pass\n\n    def handle_h_remote_msg(self, msg):\n        try:\n\
      \            d = pmt.to_python(pmt.cdr(msg))\n            self._update_h_smooth(np.array(d['h_a']),\
      \ np.array(d['h_b']), False)\n        except: pass\n\n    def work(self, input_items,\
      \ output_items):\n        in0 = input_items[0]\n        out = output_items[0]\n\
      \        n_syms = len(in0)\n        n_read = self.nitems_read(0)\n\n       \
      \ # \u63D0\u53D6 rx_time \u6807\u7B7E\n        tags = self.get_tags_in_window(0,\
      \ 0, n_syms)\n        tag_map = { (t.offset - n_read): t.value for t in tags\
      \ if pmt.to_python(t.key) == \"rx_time\" }\n\n        # --- \u6838\u5FC3\u6539\
      \u8FDB\uFF1A\u5E26\u6B63\u5219\u5316\u7684\u6C42\u9006\u903B\u8F91 ---\n   \
      \     with self.buffer_lock:\n            h11, h12, h21, h22 = self.h11.copy(),\
      \ self.h12.copy(), self.h21.copy(), self.h22.copy()\n            det = h11 *\
      \ h22 - h12 * h21\n            \n            # \u6B63\u5219\u5316\u53C2\u6570\
      \ lambda_reg\u3002\u8BE5\u503C\u8D8A\u5C0F\u8D8A\u63A5\u8FD1\u7EAF ZF\uFF0C\u8D8A\
      \u5927\u5BF9\u566A\u58F0\u6291\u5236\u8D8A\u5F3A\u3002\n            # \u5EFA\
      \u8BAE\u8303\u56F4: 1e-4 \u5230 1e-2 \u4E4B\u95F4\n            lambda_reg =\
      \ 5e-3 \n            inv_det = np.conj(det) / (np.abs(det)**2 + lambda_reg)\n\
      \n        for i in range(n_syms):\n            abs_offset = n_read + i\n   \
      \         if i in tag_map:\n                self.active_base_ts = str(pmt.to_python(tag_map[i]))\n\
      \            \n            sub_idx = abs_offset % self.items_per_frame\n   \
      \         curr_key = f\"{self.active_base_ts}_{sub_idx}\"\n\n            # \u53D1\
      \u9001\u672C\u5730 Y\n            if self.active_base_ts != \"None\":\n    \
      \            msg = pmt.cons(pmt.intern(curr_key), pmt.init_c32vector(self.fft_len,\
      \ in0[i].tolist()))\n                self.message_port_pub(pmt.intern(\"y_out\"\
      ), msg)\n\n            self.local_fifo.append((curr_key, in0[i]))\n        \
      \    old_key, old_y_local = self.local_fifo.popleft()\n            \n      \
      \      with self.buffer_lock:\n                y_remote = self.remote_y_buffer.get(old_key)\n\
      \            \n            if y_remote is not None:\n                # \u4F7F\
      \u7528\u6B63\u5219\u5316\u540E\u7684 inv_det \u8FDB\u884C\u89E3\u590D\u7528\uFF0C\
      \u6709\u6548\u51CF\u5C11\u65F6\u57DF\u6BDB\u523A\n                if self.path_id\
      \ == 1:\n                    out[i] = (h22 * old_y_local - h12 * y_remote) *\
      \ inv_det\n                else:\n                    out[i] = (-h21 * y_remote\
      \ + h11 * old_y_local) * inv_det\n            else:\n                # \u6570\
      \u636E\u7F3A\u5931\u65F6\u7684\u4F4E\u589E\u76CA\u5907\u4EFD\n             \
      \   if self.path_id == 1:\n                    m = np.abs(h11) > 1e-6\n    \
      \                tmp = np.zeros_like(h11); tmp[m] = 1.0 / (h11[m] + 1e-3)\n\
      \                    out[i] = old_y_local * tmp * 0.1 \n                else:\n\
      \                    m = np.abs(h22) > 1e-6\n                    tmp = np.zeros_like(h22);\
      \ tmp[m] = 1.0 / (h22[m] + 1e-3)\n                    out[i] = old_y_local *\
      \ tmp * 0.1\n\n        return n_syms\n"
    affinity: ''
    alias: ''
    alpha: '0.05'
    comment: ''
    delay_syms: '1000'
    fft_len: fft_len
    items_per_frame: '10'
    max_cache: '2000'
    maxoutbuf: '0'
    minoutbuf: '0'
    path_id: '2'
  states:
    _io_cache: ('mimo_precision_decoder_rx1', 'mimo_precision_decoder', [('fft_len',
      '64'), ('items_per_frame', '10'), ('path_id', '1'), ('max_cache', '2000'), ('delay_syms',
      '500'), ('alpha', '0.01')], [('0', 'complex', 64), ('h_remote_in', 'message',
      1), ('h_local_in', 'message', 1), ('y_in', 'message', 1)], [('0', 'complex',
      64), ('y_out', 'message', 1)], '', ['alpha', 'delay_syms', 'fft_len', 'items_per_frame',
      'max_cache', 'path_id'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [760, 2776.0]
    rotation: 0
    state: disabled
