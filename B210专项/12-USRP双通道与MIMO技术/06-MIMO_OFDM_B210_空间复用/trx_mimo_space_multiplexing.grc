- name: epy_block_5
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\n\nclass\
      \ dual_header_payload_demux(gr.basic_block):\n    def __init__(self, header_len=4,\
      \ payload_len=10, guard_interval=16, items_per_symbol=64, length_tag_key=\"\
      frame_len\"):\n        gr.basic_block.__init__(\n            self,\n       \
      \     name='Dual Header/Payload Demux',\n            in_sig=[np.complex64, np.complex64,\
      \ np.int8],\n            out_sig=[(np.complex64, items_per_symbol), (np.complex64,\
      \ items_per_symbol),\n                     (np.complex64, items_per_symbol),\
      \ (np.complex64, items_per_symbol)]\n        )\n        self.header_len = header_len\n\
      \        self.payload_len = payload_len\n        self.gi = guard_interval\n\
      \        self.ips = items_per_symbol\n        self.sym_size = self.ips + self.gi\n\
      \        self.frame_size = (header_len + payload_len) * self.sym_size\n    \
      \    self.len_tag_key = pmt.string_to_symbol(length_tag_key)\n\n        # \u5185\
      \u90E8\u7F13\u5B58\n        self.buf0 = np.array([], dtype=np.complex64)\n \
      \       self.buf1 = np.array([], dtype=np.complex64)\n        self.bufT = np.array([],\
      \ dtype=np.int8)\n\n        self.OUT_HDR0, self.OUT_HDR1 = 0, 1\n        self.OUT_PLD0,\
      \ self.OUT_PLD1 = 2, 3\n\n    def general_work(self, input_items, output_items):\n\
      \        print(len(input_items[0]), len(input_items[1]), len(input_items[2]))\n\
      \        # 1. \u5438\u6536\u6240\u6709\u8F93\u5165\u5230\u7F13\u5B58\n     \
      \   self.buf0 = np.concatenate((self.buf0, input_items[0]))\n        self.buf1\
      \ = np.concatenate((self.buf1, input_items[1]))\n        self.bufT = np.concatenate((self.bufT,\
      \ input_items[2]))\n        \n        n_input_actual = len(input_items[0])\n\
      \        output_count_hdr = 0\n        output_count_pld = 0\n        \n    \
      \    while True:\n            # 2. \u5BFB\u627E\u89E6\u53D1\n            active_trig\
      \ = np.where(self.bufT != 0)[0]\n            \n            if len(active_trig)\
