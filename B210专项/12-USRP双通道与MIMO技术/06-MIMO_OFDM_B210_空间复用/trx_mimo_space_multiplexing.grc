    rotation: 0
    state: enabled
- name: tx_a_sync2
  id: variable
  parameters:
    comment: ''
    value: '[val if i % 2 == 0 else 0 for i, val in enumerate(sync_word2)]'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [288, 976.0]
    rotation: 0
