  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.basic_block):\n\
      \    def __init__(self, fft_len=64):\n        gr.basic_block.__init__(\n   \
      \         self,\n            name='Dual Path Independent Block',\n         \
      \   in_sig=[(np.complex64, fft_len), (np.complex64, fft_len)], # \u4E24\u8DEF\
      \u8F93\u5165\n            out_sig=[(np.complex64, fft_len), (np.complex64, fft_len)]\
      \ # \u4E24\u8DEF\u8F93\u51FA\n        )\n        self.fft_len = fft_len\n\n\
      \    def general_work(self, input_items, output_items):\n        in0 = input_items[0]\n\
      \        in1 = input_items[1]\n        out0 = output_items[0]\n        out1\
      \ = output_items[1]\n\n        # \u83B7\u53D6\u5F53\u524D\u4E24\u8DEF\u8F93\u5165\
      \u53EF\u7528\u7684\u5411\u91CF\u4E2A\u6570\n        n_in0 = len(in0)\n     \
      \   n_in1 = len(in1)\n        if n_in0 != n_in1:\n            print(\"111111111111111111111111111\"\
      , n_in0, n_in1)\n        \n        # \u83B7\u53D6\u5F53\u524D\u4E24\u8DEF\u8F93\
      \u51FA\u53EF\u7528\u7684\u7A7A\u95F4\n        n_out0 = len(out0)\n        n_out1\
      \ = len(out1)\n\n        # \u80FD\u591F\u5904\u7406\u7684\u6570\u91CF\u53D6\u51B3\
      \u4E8E\u8F93\u5165\u548C\u8F93\u51FA\u7684\u6700\u5C0F\u503C\n        count0\
      \ = min(n_in0, n_out0)\n        count1 = min(n_in1, n_out1)\n\n        # \u5904\
      \u7406\u7B2C\u4E00\u8DEF\u6570\u636E (\u4EC5\u5F53\u6709\u6570\u636E\u4E14\u6709\
      \u7A7A\u95F4\u65F6)\n        if count0 > 0:\n            out0[:count0] = in0[:count0]\
      \ # \u8FD9\u91CC\u66FF\u6362\u6210\u4F60\u7684 ZF \u903B\u8F91\n           \
      \ self.consume(0, count0) # \u6D88\u8017\u7B2C\u4E00\u8DEF\n        else:\n\
      \            print(\"zzzzzzzzzzzzzzzzzzzzzzzzzz\") \n            count0 = 0\n\
      \n        # \u5904\u7406\u7B2C\u4E8C\u8DEF\u6570\u636E (\u72EC\u7ACB\u5224\u65AD\
      )\n        if count1 > 0:\n            out1[:count1] = in1[:count1] # \u8FD9\
      \u91CC\u66FF\u6362\u6210\u4F60\u7684 ZF \u903B\u8F91\n            self.consume(1,\
      \ count1) # \u6D88\u8017\u7B2C\u4E8C\u8DEF\n        else:\n            print(\"\
      yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy\")    \n            count1 = 0\n\n     \
      \   # \u5982\u679C\u4E24\u8DEF\u90FD\u6CA1\u6709\u5904\u7406\u4EFB\u4F55\u6570\
      \u636E\uFF0C\u8FD4\u56DE 0 \u544A\u8BC9\u8C03\u5EA6\u5668\u6682\u65F6\u6302\u8D77\
      \n        if count0 == 0 and count1 == 0:\n            print(\"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\"\
      )        \t\n            return 0\n\n        # \u8FD4\u56DE\u6BCF\u4E00\u8DEF\
      \u5B9E\u9645\u4EA7\u751F\u7684\u6837\u672C\u6570\uFF08\u6CE8\u610F\uFF1Abasic_block\
      \ \u7684\u8FD4\u56DE\u503C\u901A\u5E38\u6307\u4EA7\u751F\u7684\u8F93\u51FA\u6837\
      \u672C\u6570\uFF09\n        # \u5728\u591A\u8DEF\u975E\u5BF9\u7B49\u60C5\u51B5\
      \u4E0B\uFF0C\u901A\u5E38\u9700\u8981\u7CBE\u786E\u7BA1\u7406 produce\n     \
      \   self.produce(0, count0)\n        self.produce(1, count1)\n        \n   \
      \     return gr.WORK_CALLED_PRODUCE\n"
