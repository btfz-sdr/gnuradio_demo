      \u67E5\n                print(f\"[DEMUX_ERR] Slice error: start_idx={start_idx},\
      \ buf_len={len(self.buf0)}\")\n                break\n\n            # 6. \u6253\
      \u6807\u4E0E\u66F4\u65B0\u8BA1\u6570\n            self.add_item_tag(self.OUT_PLD0,\
