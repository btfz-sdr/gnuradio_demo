      \ + i] = self.buf0[s:e]\n                    output_items[self.OUT_PLD1][output_count_pld\
      \ + i] = self.buf1[s:e]\n            except ValueError as e:\n             \
      \   # \u7406\u8BBA\u4E0A\u6709\u4E86\u4E0A\u9762\u7684\u957F\u5EA6\u68C0\u67E5\
      \u4E0D\u4F1A\u8FDB\u8FD9\u91CC\uFF0C\u52A0\u4E2A\u4FDD\u9669\u7528\u4E8E\u6392\
      \u67E5\n                print(f\"[DEMUX_ERR] Slice error: start_idx={start_idx},\
